# Carbon Proxy Configuration
# Copy to .env and fill in values

# --- Required ---
UPSTREAM_URL=http://localhost:8080
# LISTEN_PORT=8080
# SQLITE_PATH=/data/carbon.db

# --- API Key Mapping (comma-separated key:name pairs) ---
# Maps bearer tokens to source names for tracking
# API_KEYS=sk-webui:openwebui,sk-claude:claude-code

# --- Carbon Intensity ---
# Static fallback (gCO2/kWh). Default: 400
# CARBON_INTENSITY=400

# Real-time carbon intensity (overrides static value if set)
# ELECTRICITYMAP_API_KEY=
# ELECTRICITYMAP_ZONE=US-CAL-CISO

# --- Power Measurement ---
# POWER_SAMPLE_HZ=10
# Manual TDP override (watts). Auto-detected if not set.
# TDP_CPU_WATTS=0
# TDP_GPU_WATTS=0

# --- Offset Purchasing ---
# Provider: "cnaught", "tree-nation", or "both"
# OFFSET_PROVIDER=cnaught

# Required bearer token for POST /carbon/offset (disabled if empty)
# OFFSET_API_KEY=

# CNaught API (https://cnaught.com)
# CNAUGHT_API_KEY=
# CNAUGHT_PORTFOLIO_ID=          # Optional, uses default portfolio if empty

# Tree-Nation API (https://tree-nation.com)
# TREE_NATION_API_KEY=
# TREE_NATION_PLANTER_ID=0
# TREE_NATION_SPECIES_ID=0

# --- TRMNL e-ink Display ---
# Push carbon summary to TRMNL device via webhook
# TRMNL_ENABLED=false
# TRMNL_PLUGIN_UUID=
# TRMNL_PUSH_INTERVAL=300
